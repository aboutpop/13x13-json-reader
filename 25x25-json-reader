<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GLYPH ENGINE 3 — 25x25 JSON Reader</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.0/index.min.css">
<style>
  :root{
    --bg:#0f0f10;
    --panel:#161618;
    --panel-2:#1c1c1f;
    --line:#2a2a2e;
    --line-2:#3a3a3f;
    --fg:#e8e8ea;
    --fg-dim:#9a9a9e;
    --accent:#ff3b30;
    --accent-2:#ff9500;
    --on:#f5f5f5;
    --off:#202024;
    --off-ring:#2e2e33;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--fg);font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
  body{min-height:100vh;padding:24px}
  .wrap{max-width:1280px;margin:0 auto}

  /* Header */
  header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;background:var(--panel);border:1px solid var(--line);border-radius:14px;margin-bottom:18px}
  .brand{display:flex;align-items:center;gap:12px}
  .logo{width:34px;height:34px;border-radius:50%;background:radial-gradient(circle at 30% 30%,#3a3a3f,#0a0a0b);border:1px solid var(--line-2);position:relative}
  .logo::after{content:"";position:absolute;inset:6px;border-radius:50%;background:radial-gradient(circle,#ff3b30 0%,#8b1a12 70%,#000 100%)}
  h1{font-size:18px;letter-spacing:2px;margin:0;font-weight:700}
  .sub{font-size:11px;color:var(--fg-dim);letter-spacing:1.5px;margin-top:2px}
  .status{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--fg-dim);letter-spacing:1px}
  .dot{width:8px;height:8px;border-radius:50%;background:#30d158;box-shadow:0 0 8px #30d158}

  /* Layout */
  .grid{display:grid;grid-template-columns:1.1fr 1fr;gap:18px}
  @media(max-width:960px){.grid{grid-template-columns:1fr}}

  .card{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:18px}
  .card h2{font-size:11px;letter-spacing:2px;color:var(--fg-dim);margin:0 0 14px 0;font-weight:600}

  /* Matrix area */
  .matrix-stage{display:flex;flex-direction:column;align-items:center;gap:14px}
  .matrix-label{font-size:11px;letter-spacing:2.5px;color:var(--fg-dim)}
  .matrix-wrap{position:relative;width:min(560px,100%);aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;background:radial-gradient(circle at 50% 50%,#1a1a1d 0%,#0d0d0f 70%);border-radius:50%;border:1px solid var(--line)}
  .matrix-wrap::before{content:"";position:absolute;inset:10px;border-radius:50%;border:1px dashed var(--line-2);opacity:.4}
  .matrix{display:grid;grid-template-columns:repeat(25,1fr);grid-template-rows:repeat(25,1fr);gap:2px;padding:18px;width:86%;height:86%;border-radius:50%;background:rgba(0,0,0,.35)}
  .cell{aspect-ratio:1/1;border-radius:2px;background:var(--off);border:1px solid var(--off-ring);transition:background .08s ease, box-shadow .08s ease, border-color .08s ease}
  .cell.on{background:var(--on);border-color:#fff;box-shadow:0 0 6px rgba(255,255,255,.55)}
  .cell.off{opacity:.18}
  .cell.hover{border-color:var(--accent-2)}

  .intensity-row{display:flex;align-items:center;gap:12px;width:100%;max-width:560px}
  .intensity-row label{font-size:11px;letter-spacing:2px;color:var(--fg-dim);min-width:140px}
  .intensity-row input[type=range]{flex:1;accent-color:var(--accent)}
  .intensity-val{font-size:11px;color:var(--fg);min-width:40px;text-align:right;font-variant-numeric:tabular-nums}

  /* Controls */
  .section-title{font-size:11px;letter-spacing:2px;color:var(--fg-dim);margin:18px 0 10px;font-weight:600}
  .btn-row{display:flex;flex-wrap:wrap;gap:8px}
  button{background:var(--panel-2);color:var(--fg);border:1px solid var(--line-2);border-radius:8px;padding:9px 14px;font-size:12px;letter-spacing:1.2px;cursor:pointer;font-family:inherit;transition:all .15s ease}
  button:hover{border-color:var(--fg-dim);background:#222226}
  button.primary{background:var(--accent);color:#fff;border-color:var(--accent)}
  button.primary:hover{background:#ff5a4f;border-color:#ff5a4f}
  button.warn{color:#ffb020;border-color:#5a4a1a}
  button.warn:hover{background:#2a2410}
  button.danger{color:#ff453a;border-color:#5a1a15}
  button.danger:hover{background:#2a1010}

  .fps{font-size:11px;color:var(--fg-dim);letter-spacing:1px;margin-top:6px}

  /* Data utils */
  .drop{border:1px dashed var(--line-2);border-radius:12px;padding:22px;text-align:center;color:var(--fg-dim);font-size:12px;letter-spacing:1px;background:var(--panel-2);transition:all .2s;cursor:pointer}
  .drop.drag{border-color:var(--accent);background:#1a1412;color:var(--fg)}
  .drop small{display:block;margin-top:6px;font-size:10px;opacity:.7}
  .drop input{display:none}

  .log{margin-top:12px;padding:10px 12px;background:#0a0a0b;border:1px solid var(--line);border-radius:8px;font-size:11px;color:var(--fg-dim);min-height:40px;font-family:'SF Mono',Menlo,monospace;letter-spacing:.5px}
  .log.ok{color:#30d158;border-color:#1a3a25}
  .log.err{color:#ff453a;border-color:#3a1a1a}

  .actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}

  /* Toast */
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:#1c1c1f;border:1px solid var(--line-2);padding:10px 18px;border-radius:10px;font-size:12px;letter-spacing:1px;opacity:0;transition:all .25s ease;pointer-events:none;z-index:100}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

  footer{margin-top:20px;text-align:center;font-size:10px;color:var(--fg-dim);letter-spacing:2px}
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="brand">
      <div class="logo"></div>
      <div>
        <h1>GLYPH ENGINE 3</h1>
        <div class="sub">Nothing OS // LED Dot Matrix Synthesizer</div>
      </div>
    </div>
    <div class="status">
      <div class="dot"></div>
      <span>NOTHING® CONCEPT DEVONION ▶ <span id="fps">01</span>/01 FPS</span>
    </div>
  </header>

  <div class="grid">
    <!-- LEFT: Matrix -->
    <div class="card">
      <h2>MATRIX 25×25 (V1 COMPLIANT)</h2>
      <div class="matrix-stage">
        <div class="matrix-label">FH1 : SEQUENCER</div>
        <div class="matrix-wrap">
          <div class="matrix" id="matrix"></div>
        </div>
        <div class="intensity-row">
          <label>GLYPH INTENSITY</label>
          <input type="range" id="intensity" min="0" max="255" value="255">
          <span class="intensity-val" id="intVal">255</span>
        </div>
        <div class="fps">V1 COMPATIBLE STEP RATIO: 0–255 GS</div>
      </div>

      <div class="section-title">TRANSFORM MODULES</div>
      <div class="btn-row">
        <button id="btnFill">FILL</button>
        <button id="btnInvert">INVERT</button>
        <button id="btnMirror">MIRROR</button>
        <button id="btnFlip">FLIP</button>
        <button id="btnRotate">ROTATE</button>
        <button id="btnClear">CLEAR</button>
        <button id="btnFlash">FLASH</button>
      </div>

      <div class="section-title">HARDWARE SEGMENTS</div>
      <div class="btn-row">
        <button id="btnReset" class="danger">⚠️ DO OVER</button>
      </div>
      <div class="fps" style="margin-top:6px">SYSTEM RESET — ERASES ALL DATA & RESTARTS SESSION</div>
    </div>

    <!-- RIGHT: Data Utils -->
    <div class="card">
      <h2>DATA UTILS</h2>

      <div class="btn-row" style="margin-bottom:12px">
        <button id="btnImport" class="primary">IMPORT COMPILER</button>
        <button id="btnExport">JSON COMPILE & EXPORT</button>
      </div>

      <div class="drop" id="drop">
        ✕ ️ DRAG FILE HERE OR CLICK TO DIRECTORY
        <small>*.json formats containing Glyph v1 array structures</small>
        <input type="file" id="fileInput" accept=".json,application/json">
      </div>

      <div class="actions">
        <button id="btnCancel">CANCEL</button>
        <button id="btnLoad">LOAD COMPOSITION</button>
        <button id="btnParse">EXPORT ENGINE PARSE</button>
        <button id="btnCopyRaw">COPY RAW</button>
        <button id="btnSave">SAVE FILE</button>
      </div>

      <div class="log" id="log">SYSTEM STANDBY</div>
    </div>
  </div>

  <footer>DESIGNED IN LONDON // RECONSTRUCTED FOR NOTHING 3 [VER 3.1.0-STABLE] INTERNAL LOADER [V1 FORMAT]</footer>
</div>

<div class="toast" id="toast"></div>

<script>
/* =========================================================
   25x25 matrix with circular mask (489 active pixels)
   Row pixel counts (centered):
   1:7  2:11 3:15 4:17 5:19 6:21 7:21 8:23 9:23
   10-16:25
   17:23 18:23 19:21 20:21 21:19 22:17 23:15 24:11 25:7
   ========================================================= */
const SIZE = 25;
const rowPixels = [7,11,15,17,19,21,21,23,23,25,25,25,25,25,25,25,23,23,21,21,19,17,15,11,7];
const totalActive = rowPixels.reduce((a,b)=>a+b,0); // 489

// Build mask: true = active pixel, false = hidden
const mask = [];
for(let r=0;r<SIZE;r++){
  const count = rowPixels[r];
  const offset = Math.floor((SIZE - count)/2);
  const row = [];
  for(let c=0;c<SIZE;c++){
    row.push(c >= offset && c < offset + count);
  }
  mask.push(row);
}

// State: 0=off, 1=on (only meaningful where mask is true)
const state = Array.from({length:SIZE},()=>Array(SIZE).fill(0));

const matrixEl = document.getElementById('matrix');
const cells = [];

function buildMatrix(){
  matrixEl.innerHTML = '';
  cells.length = 0;
  for(let r=0;r<SIZE;r++){
    const row = [];
    for(let c=0;c<SIZE;c++){
      const cell = document.createElement('div');
      cell.className = 'cell ' + (mask[r][c] ? 'off' : 'off');
      cell.dataset.r = r;
      cell.dataset.c = c;
      if(!mask[r][c]){
        cell.style.visibility = 'hidden';
      }
      cell.addEventListener('pointerdown', (e)=>{
        e.preventDefault();
        toggleCell(r,c);
      });
      cell.addEventListener('pointerenter', (e)=>{
        if(e.buttons === 1) toggleCell(r,c,true);
      });
      matrixEl.appendChild(cell);
      row.push(cell);
    }
    cells.push(row);
  }
  render();
}

function toggleCell(r,c,forceOn){
  if(!mask[r][c]) return;
  if(forceOn) state[r][c] = 1;
  else state[r][c] = state[r][c] ? 0 : 1;
  render();
}

function render(){
  for(let r=0;r<SIZE;r++){
    for(let c=0;c<SIZE;c++){
      const cell = cells[r][c];
      if(!mask[r][c]) continue;
      cell.classList.toggle('on', state[r][c] === 1);
      cell.classList.toggle('off', state[r][c] === 0);
    }
  }
}

/* ---------- Intensity (visual only for this version) ---------- */
const intensityEl = document.getElementById('intensity');
const intValEl = document.getElementById('intVal');
intensityEl.addEventListener('input', ()=>{
  intValEl.textContent = intensityEl.value;
});

/* ---------- Transforms ---------- */
function fillAll(){
  for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++) if(mask[r][c]) state[r][c]=1;
  render(); log('FILL applied','ok');
}
function invertAll(){
  for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++) if(mask[r][c]) state[r][c] = state[r][c]?0:1;
  render(); log('INVERT applied','ok');
}
function mirrorH(){
  const copy = state.map(r=>r.slice());
  for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++) if(mask[r][c]) state[r][c] = copy[r][SIZE-1-c] && mask[r][SIZE-1-c] ? copy[r][SIZE-1-c] : 0;
  render(); log('MIRROR applied','ok');
}
function flipV(){
  const copy = state.map(r=>r.slice());
  for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++) if(mask[r][c]) state[r][c] = copy[SIZE-1-r][c] && mask[SIZE-1-r][c] ? copy[SIZE-1-r][c] : 0;
  render(); log('FLIP applied','ok');
}
function rotateCW(){
  const copy = state.map(r=>r.slice());
  const newState = Array.from({length:SIZE},()=>Array(SIZE).fill(0));
  for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++){
    newState[c][SIZE-1-r] = copy[r][c];
  }
  for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++){
    state[r][c] = mask[r][c] && mask[SIZE-1-c][r] ? newState[r][c] : 0;
  }
  render(); log('ROTATE 90° CW applied','ok');
}
function clearAll(){
  for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++) state[r][c]=0;
  render(); log('CLEAR applied','ok');
}
function flash(){
  let n=0;
  const iv = setInterval(()=>{
    for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++) if(mask[r][c]) state[r][c] = n%2;
    render();
    n++;
    if(n>=6){clearInterval(iv); clearAll(); log('FLASH complete','ok');}
  },120);
}
function doOver(){
  if(!confirm('️ This will erase all data and restart the session. Continue?')) return;
  for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++) state[r][c]=0;
  render();
  logEl.className='log';
  logEl.textContent='SYSTEM RESET — SESSION RESTARTED';
  toast('Session restarted');
}

document.getElementById('btnFill').onclick = fillAll;
document.getElementById('btnInvert').onclick = invertAll;
document.getElementById('btnMirror').onclick = mirrorH;
document.getElementById('btnFlip').onclick = flipV;
document.getElementById('btnRotate').onclick = rotateCW;
document.getElementById('btnClear').onclick = clearAll;
document.getElementById('btnFlash').onclick = flash;
document.getElementById('btnReset').onclick = doOver;

/* ---------- Data Utils ---------- */
const logEl = document.getElementById('log');
function log(msg, type){
  logEl.textContent = msg;
  logEl.className = 'log' + (type ? ' '+type : '');
}

const drop = document.getElementById('drop');
const fileInput = document.getElementById('fileInput');
drop.addEventListener('click', ()=>fileInput.click());
drop.addEventListener('dragover', (e)=>{e.preventDefault();drop.classList.add('drag');});
drop.addEventListener('dragleave', ()=>drop.classList.remove('drag'));
drop.addEventListener('drop', (e)=>{
  e.preventDefault();
  drop.classList.remove('drag');
  const f = e.dataTransfer.files[0];
  if(f) handleFile(f);
});
fileInput.addEventListener('change', (e)=>{
  const f = e.target.files[0];
  if(f) handleFile(f);
});

let pendingJSON = null;
function handleFile(f){
  const reader = new FileReader();
  reader.onload = (e)=>{
    try{
      const data = JSON.parse(e.target.result);
      pendingJSON = data;
      log(`Loaded: ${f.name} (${(f.size/1024).toFixed(1)} KB)`,'ok');
      toast('File ready — click LOAD COMPOSITION');
    }catch(err){
      log('Parse error: '+err.message,'err');
    }
  };
  reader.readAsText(f);
}

document.getElementById('btnLoad').onclick = ()=>{
  if(!pendingJSON){log('No file loaded yet','err');return;}
  applyComposition(pendingJSON);
};

document.getElementById('btnCancel').onclick = ()=>{
  pendingJSON = null;
  fileInput.value = '';
  log('CANCEL — cleared','');
};

document.getElementById('btnParse').onclick = ()=>{
  const out = buildExport();
  log('Export engine parsed — '+out.rows.length+' rows','ok');
};

document.getElementById('btnCopyRaw').onclick = ()=>{
  const raw = JSON.stringify(buildExport(), null, 2);
  navigator.clipboard.writeText(raw).then(()=>{
    toast('Copied to clipboard');
    log('Raw JSON copied','ok');
  }).catch(()=>log('Copy failed','err'));
};

document.getElementById('btnSave').onclick = ()=>{
  const raw = JSON.stringify(buildExport(), null, 2);
  const blob = new Blob([raw],{type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'glyph-engine-3-composition.json';
  a.click();
  URL.revokeObjectURL(url);
  toast('File saved');
  log('File saved','ok');
};

document.getElementById('btnImport').onclick = ()=>fileInput.click();
document.getElementById('btnExport').onclick = ()=>{
  const out = buildExport();
  const raw = JSON.stringify(out,null,2);
  const blob = new Blob([raw],{type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'glyph-engine-3-export.json';
  a.click();
  URL.revokeObjectURL(url);
  log('Composition exported','ok');
  toast('Exported JSON');
};

/* ---------- Composition apply / build ---------- */
function applyComposition(data){
  // Accept either flat array of 489 (0/1) or 25x25 nested
  try{
    clearAll();
    if(Array.isArray(data)){
      if(data.length === SIZE*SIZE){
        for(let i=0;i<data.length;i++){
          const r = Math.floor(i/SIZE), c = i%SIZE;
          if(mask[r][c]) state[r][c] = data[i] ? 1 : 0;
        }
      } else if(Array.isArray(data[0])){
        for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++){
          if(mask[r][c] && data[r] && data[r][c] !== undefined) state[r][c] = data[r][c] ? 1 : 0;
        }
      } else if(data.length === totalActive){
        // flat active-only
        let idx = 0;
        for(let r=0;r<SIZE;r++) for(let c=0;c<SIZE;c++){
          if(mask[r][c]){ state[r][c] = data[idx++] ? 1 : 0; }
        }
      }
    } else if(data && typeof data === 'object'){
      // Try data.rows or data.matrix
      const src = data.rows || data.matrix || data.glyph || data.data;
      if(src) applyComposition(src);
    }
    render();
    log('Composition loaded successfully','ok');
  }catch(err){
    log('Apply error: '+err.message,'err');
  }
}

function buildExport(){
  const rows = [];
  const activeOnly = [];
  for(let r=0;r<SIZE;r++){
    const row = [];
    for(let c=0;c<SIZE;c++){
      row.push(mask[r][c] ? (state[r][c]?1:0) : 0);
      if(mask[r][c]) activeOnly.push(state[r][c]?1:0);
    }
    rows.push(row);
  }
  return {
    engine:'GLYPH ENGINE 3',
    version:'V1',
    matrix:'25x25',
    activePixels: totalActive,
    rows,
    activeOnly,
    intensity: parseInt(intensityEl.value,10),
    timestamp: new Date().toISOString()
  };
}

/* ---------- Toast ---------- */
const toastEl = document.getElementById('toast');
let toastTimer;
function toast(msg){
  toastEl.textContent = msg;
  toastEl.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>toastEl.classList.remove('show'), 1800);
}

/* ---------- Init ---------- */
buildMatrix();
log(`SYSTEM STANDBY — 25×25 matrix ready (${totalActive} active pixels)`,'');
</script>
</body>
</html>

